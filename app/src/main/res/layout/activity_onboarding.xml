<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Top label (optional, like "Onboarding / Template 4.1") -->
    <TextView
        android:id="@+id/tvTopLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Onboarding / Template 4.1"
        android:textSize="11sp"
        android:textColor="#AAAAAA"
        android:fontFamily="sans-serif"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:visibility="gone"/>

    <!-- Circular grey background for illustration -->
    <View
        android:id="@+id/viewCircleBg"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:background="@drawable/circle_bg"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvWelcome"
        app:layout_constraintVertical_bias="0.45"
        android:layout_marginBottom="32dp"/>

    <!-- Onboarding illustration image -->
    <ImageView
        android:id="@+id/ivIllustration"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:src="@drawable/onboarding_image"
        android:scaleType="centerInside"
        android:contentDescription="Onboarding Illustration"
        app:layout_constraintTop_toTopOf="@id/viewCircleBg"
        app:layout_constraintBottom_toBottomOf="@id/viewCircleBg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Welcome Title -->
    <TextView
        android:id="@+id/tvWelcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Welcome to FastMart"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvSubtitle"
        android:layout_marginBottom="12dp"/>

    <!-- Subtitle -->
    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Discover products you love,\ndelivered to your door."
        android:textSize="14sp"
        android:textColor="#888888"
        android:fontFamily="sans-serif"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnGetStarted"
        android:layout_marginBottom="40dp"/>

    <!-- Get Started Button -->
    <Button
        android:id="@+id/btnGetStarted"
        android:layout_width="0dp"
        android:layout_height="58dp"
        android:text="Get Started  →"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:background="@drawable/btn_black_rounded"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>