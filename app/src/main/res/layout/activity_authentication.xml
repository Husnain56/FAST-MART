<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#111111"
    tools:context=".AuthenticationActivity">

    <!-- ===== TOP DARK SECTION (static) ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:gravity="bottom"
        android:paddingBottom="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Get Started now"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:fontFamily="sans-serif-medium"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Create an account or log in to explore about our app"
            android:textSize="13sp"
            android:textColor="#AAAAAA"
            android:fontFamily="sans-serif"
            android:lineSpacingExtra="3dp"/>

    </LinearLayout>

    <!-- ===== BOTTOM WHITE CARD (static shell) ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_white_card"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="28dp"
        android:paddingBottom="32dp">

        <!-- Tab Row: Log In / Sign Up (static) -->
        <LinearLayout
            android:id="@+id/layoutTabs"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_tab_row"
            android:padding="4dp">

            <TextView
                android:id="@+id/tabLogin"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Log In"
                android:textSize="14sp"
                android:textColor="#1A1A1A"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_tab_selected"
                android:fontFamily="sans-serif-medium"/>

            <TextView
                android:id="@+id/tabSignUp"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Sign Up"
                android:textSize="14sp"
                android:textColor="#888888"
                android:gravity="center"
                android:background="@android:color/transparent"
                android:fontFamily="sans-serif"/>

        </LinearLayout>

        <!-- Fragment Container — swaps between Login & SignUp -->
        <FrameLayout
            android:id="@+id/fragmentContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"/>

    </LinearLayout>

</LinearLayout>