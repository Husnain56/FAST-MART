<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="320dp"
    android:layout_height="200dp"
    android:id="@+id/cvDeal"
    android:layout_marginEnd="25dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#F5F5F5">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="14dp">

        <ImageView
            android:id="@+id/iv_deal_image"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_launcher_foreground"
            android:contentDescription="Deal product image" />

        <!-- Favourite Button -->
        <ImageView
            android:id="@+id/iv_deal_favourite"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true"
            android:src="@drawable/ic_favourites"
            android:padding="4dp"
            android:contentDescription="Add to favourites"
            app:tint="#1A1A1A" />

        <!-- Text Content -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/iv_deal_image"
            android:layout_centerVertical="true"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="36dp"
            android:orientation="vertical">

            <!-- Category -->
            <TextView
                android:id="@+id/tv_deal_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Microphones"
                android:textSize="11sp"
                android:textColor="#888888" />

            <!-- Price Row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_deal_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$108.20"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#E53935" />

                <TextView
                    android:id="@+id/tv_deal_original_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="$199.99"
                    android:textSize="11sp"
                    android:textColor="#AAAAAA" />

            </LinearLayout>

            <!-- Product Name -->
            <TextView
                android:id="@+id/tv_deal_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="RØDE PodMic"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Product Description -->
            <TextView
                android:id="@+id/tv_deal_description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Dynamic microphone, Speaker microphone"
                android:textSize="10sp"
                android:textColor="#AAAAAA"
                android:maxLines="2"
                android:ellipsize="end" />

        </LinearLayout>

    </RelativeLayout>

</androidx.cardview.widget.CardView>